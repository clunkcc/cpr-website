---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 Hello! Welcome to Cassie's Practice Resuscitation Training!</h1>
			<p>
				Low-cost, pay-what-you-can CPR and first aid training for community. Practical skills, queer trainer, and accessible sessions so more people can act confidently in an emergency.
			</p>

			<div class="grid">
				<div class="card">
					<h2>Whats On Offer:</h2>
					<ul>
					<li>Hands-on CPR (adult, child, infant) — short practical sessions</li>
					<li>Basic first aid — wound care, burns, choking</li>
					<li>A range of training options — from assessment-only refresher sessions to full, in-depth preparation before assessment</li>
					<li>Community sessions tailored for clubs and groups</li>
					</ul>
					<p class="small">
					We run refundable low-cost sessions and a pay-what-you-can model so cost isn’t a barrier.
					</p>
				</div>
				<div class="card">
					<h2>How It Works</h2>
					<ol>
					<li>Send me a message through the <a href="/contact">contact form</a></li>
					<li>I'll put you on the waitlist for the next available session</li>
					<li>If you have a large group, I'll work with you to organise a session that meets your group's needs</li>
					</ol>
				</div>
			</div>
			<p class="small" style="margin-top:1rem">
				If you’d like me to visit your community group, non-profit, or school, <a href="/contact">get in touch</a> — I prioritise groups with limited access to affordable training.
			</p>
		</main>
		<Footer />
	</body>
</html>
