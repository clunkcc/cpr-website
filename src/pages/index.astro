---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script is:inline>
			function checkPassword() {
				var password = "mypassword"; // Set your password here
				
				var protectedContent = document.getElementById("protectedContent");
				var userInput = prompt("Please enter the password to access this site:");
				if (!protectedContent) return;
				while (userInput !== password) {
					userInput = prompt("Incorrect password. Please try again:");
				}
				protectedContent.style.display = "block";
			}

			window.addEventListener("DOMContentLoaded", checkPassword);
		</script>
	</head>
	<body id="protectedContent" style="display:none;">
		<Header />
		<main>
			<h1>👋 Hello! Welcome to Cassie's Practice Resuscitation Training!</h1>
			<p>
				Nationally recognised, low-cost, pay-what-you-can CPR and first aid training for community. Practical skills, queer trainer, and accessible sessions so more people can act with confidence in an emergency.
			</p>

			<div class="grid">
				<div class="card">
					<h2>What's On Offer:</h2>
					<ul>
					<li>Provide Cardiopulmonary Resuscitation (HLTAID009) — short practical sessions</li>
					<li>Provide First Aid (HLTAID011) — wound care, burns, choking</li>
					<li>A range of training options — from assessment-only refresher sessions to full, in-depth preparation before assessment</li>
					<li>Community sessions tailored for clubs and groups</li>
					</ul>
					<p class="small">
					We run affordable low-cost sessions under a pay-what-you-can model so cost isn’t a barrier.
					</p>
				</div>
				<div class="card">
					<h2>How It Works</h2>
					<ol>
					<li>Send me a message through the <a href="/contact">contact form</a></li>
					<li>I'll put you on the waitlist for the next available session</li>
					<li>If you have a large group, I'll work with you to organise a session that meets your group's needs</li>
					<li>After you complete training, successful participants receive a nationally recognised Statement of Attainment issued by our training partner, Business Wise First Aid Training (RTO 45193). </li>
					</ol>
				</div>
			</div>
			<p class="small" style="margin-top:1rem">
				If you’d like me to visit your community group, non-profit, or school, <a href="/contact">get in touch</a> — I prioritise groups with limited access to affordable training.
			</p>
		</main>
		<Footer />
	</body>
</html>
